{
  "name": "gityo",
  "version": "0.0.0",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "lint": "tsc --noEmit && eslint .",
    "fix": "tsc --noEmit && eslint . --fix",
    "test": "pnpm build && docker build --file ./Dockerfile.test --tag gityo-test . && docker run --rm gityo-test",
    "test:docker": "pnpm build && docker build --file ./Dockerfile.test --tag gityo-test . && docker run --rm gityo-test",
    "start": "tsx --watch ./src/index.ts",
    "build": "tsdown --config ./tsdown.config.ts",
    "dev": "concurrently --names \"R,T\" --prefix-colors \"blue.dim,magenta.dim\" \"tsdown --config ./tsdown.config.ts --watch\" \"tsc --noEmit --watch\"",
    "dev:tsc": "tsc --noEmit --watch"
  },
  "bin": {
    "gityo": "./dist/index.js"
  },
  "dependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@eslint/compat": "^1.4.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@inquirer/prompts": "^8.3.0",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "ai": "^6.0.116",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "noarg": "^3.1.9",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rolldown": "1.0.0-rc.9",
    "tsdown": "^0.15.9",
    "tslib": "^2.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "zod": "^4.3.6"
  }
}
